# === RFAF Analytics Platform - Variables de Entorno ===
# Copia este archivo: cp .env.example .env
# Luego rellena con tus API keys reales

# -- Anthropic (Claude) --
ANTHROPIC_API_KEY=sk-ant-...

# -- Google AI (Gemini 2.5 Flash) --
GOOGLE_API_KEY=AIza...

# -- PostgreSQL --
DATABASE_URL=postgresql+asyncpg://rfaf_user:rfaf_pass@localhost:5432/rfaf_analytics

# -- Redis + Celery --
REDIS_URL=redis://localhost:6379/0

# -- Stripe (pagos) --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# -- Resend (email) --
RESEND_API_KEY=re_...

# -- Cloudflare R2 (storage) --
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=rfaf-analytics
CLOUDFLARE_R2_ENDPOINT=https://....r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.rfaf-analytics.es

# -- Auth --
NEXTAUTH_SECRET=cambiar-en-produccion
JWT_SECRET=cambiar-en-produccion

# -- Sentry --
SENTRY_DSN=

# -- PostHog --
POSTHOG_API_KEY=phc_...
