# === RFAF Analytics Platform - Variables de Entorno ===
# Copia este archivo: cp .env.example .env
# Luego rellena con tus API keys reales

# -- Anthropic (Claude) --
ANTHROPIC_API_KEY=sk-ant-...

# -- Google AI (Gemini 2.5 Flash) --
GOOGLE_API_KEY=AIza...

# -- PostgreSQL --
DATABASE_URL=postgresql+asyncpg://rfaf_user:rfaf_pass@localhost:5432/rfaf_analytics

# -- Redis + Celery --
REDIS_URL=redis://localhost:6379/0

# -- Stripe (pagos) --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_BASICO=price_basico
STRIPE_PRICE_PROFESIONAL=price_profesional
STRIPE_PRICE_FEDERADO=price_federado
STRIPE_PORTAL_RETURN_URL=https://rfaf-analytics.es/dashboard

# -- Resend (email) --
RESEND_API_KEY=re_...

# -- Cloudflare R2 (storage) --
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=rfaf-analytics
CLOUDFLARE_R2_ENDPOINT=https://....r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.rfaf-analytics.es

# -- Auth --
NEXTAUTH_SECRET=cambiar-en-produccion
JWT_SECRET=cambiar-en-produccion

# -- Sentry --
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
ENVIRONMENT=production

# -- PostHog --
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://eu.posthog.com

# -- CORS (produccion) --
ALLOWED_ORIGINS=https://rfaf-analytics.es,https://www.rfaf-analytics.es

# -- Frontend PostHog (Next.js env vars must be NEXT_PUBLIC_) --
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
NEXT_PUBLIC_API_URL=https://api.rfaf-analytics.es

# -- Frontend URL (para enlaces en emails) --
FRONTEND_URL=https://rfaf-analytics.es
